# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db

# =========================================================
# ### DATA SCIENCE & MACHINE LEARNING SPECIFIC ###
# =========================================================

# 1. Dataset Directory
# The IEEE-CIS dataset is too large for GitHub (>100MB). 
# Keep your raw and processed data in this folder locally.
data/

# 2. Individual Data Files
# Prevents accidental upload of data files outside the data folder.
*.csv
*.zip
*.parquet
*.gz
*.jsonl

# 3. Model Exports & Weights
# Saved model checkpoints (e.g., Random Forest or XGBoost models) are large binary files.
models/*.pkl
models/*.joblib
models/*.h5
models/*.onnx
models/*.keras

# 4. Logs & Visualization Outputs
# Ignore local logs, keep the reports/ folder for final plots only.
*.log
.ruff_cache/
